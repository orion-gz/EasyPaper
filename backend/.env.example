OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gemma4:e4b
MAX_FILE_SIZE_MB=50
SESSION_TTL_HOURS=24
UPLOAD_DIR=./uploads
CACHE_DIR=./cache
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# 기본 사용자 설정 (처음 시작 시 아이디: admin, 비밀번호: admin)
# 로그인 후 설정 화면에서 비밀번호를 변경하면 자동으로 .env에 해시값이 저장됩니다.
# APP_USERNAME=admin
# SECRET_KEY=generate_some_random_secret_key_here

# API 제공업체 설정
TRANS_PROVIDER=ollama
TRANS_MODEL=gemma4:e4b
CHAT_PROVIDER=ollama
CHAT_MODEL=gemma4:e4b

# 외부 API 키 설정 (필요에 따라 작성)
OPENAI_API_KEY=
GEMINI_API_KEY=
CLAUDE_API_KEY=

# 서비스 구동 호스트 및 포트 설정
APP_HOST=0.0.0.0
APP_PORT=8000

# Antigravity CLI (agy) 절대 경로 설정 (선택 사항)
AGY_PATH=/home/ubuntu/.local/bin/agy

